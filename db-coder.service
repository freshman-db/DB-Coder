[Unit]
Description=db-coder AI Coding Agent
After=network.target docker.service

[Service]
Type=simple
User=db
WorkingDirectory=/home/db/projects/db-coder
ExecStart=/home/db/.nvm/versions/node/v24.13.0/bin/node /home/db/projects/db-coder/dist/index.js serve --project /home/db/projects/target-project
Restart=always
RestartSec=10
MemoryMax=1200M
KillMode=mixed
StartLimitBurst=5
StartLimitIntervalSec=300
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
